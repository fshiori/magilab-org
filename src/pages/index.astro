---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-12 mt-5">
    <div class="text-xl py-1">Welcome to</div>
    <div class="text-5xl font-bold">Magi Lab</div>
    <div class="text-3xl py-3 font-bold">Engineering, AI, and Life Observations</div>
    <div class="py-2">
      <text class="text-lg">
        Exploring the intersection of technology, artificial intelligence, and human experience. 
        This is a personal experimental laboratory where ideas come to life.
      </text>
    </div>

    <!-- Terminal Status Bar -->
    <div class="mt-6 font-mono text-sm bg-base-300 p-3 rounded-lg border border-white/10 shadow-inner">
      <div class="flex items-center gap-2 mb-1">
        <span class="w-3 h-3 rounded-full bg-error"></span>
        <span class="w-3 h-3 rounded-full bg-warning"></span>
        <span class="w-3 h-3 rounded-full bg-success"></span>
        <span class="ml-2 text-white/50 text-xs">magi-lab — status</span>
      </div>
      <div class="text-success">
        <span class="text-white/50">$</span> systemctl status magi-engine <span class="bg-success text-black px-1 ml-1 rounded">ACTIVE</span>
      </div>
      <div class="text-white/70">
        <span class="text-white/50">$</span> last-update: 2026-04-24 15:41 CST
      </div>
    </div>

    <div class="mt-8">
      <a class="btn" href="https://fshiori.substack.com/" target="_blank"> Eric 觀察筆記</a>
      <a href="/projects" class="btn btn-outline ml-5"> View Projects</a>
    </div>
  </div>

  <div>
    <div class="text-3xl w-full font-bold mb-5">Core Projects</div>
  </div>

  <HorizontalCard
    title="MAGI (AI Debate System)"
    img="/post_img.webp"
    desc="多模型 AI 辯論系統"
    url="https://github.com/fshiori/magi"
    badge="Researching"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="FinexLend (Fintech Utility)"
    img="/post_img.webp"
    desc="Bitfinex 自動化放貸工具"
    url="https://finexlend.cc"
    badge="Active"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="ClassZero (Kids Interactive Story)"
    img="/post_img.webp"
    desc="小朋友互動故事網站"
    url="https://classzero.magilab.org"
    badge="Building"
  />
</BaseLayout>
