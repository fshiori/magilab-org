---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-12 mt-5">
    <div class="text-xl py-1 text-primary font-mono">/root/eric-chen</div>
    <div class="text-5xl font-bold mb-4">Magi Lab</div>
    <div class="text-2xl py-2 font-bold text-white/90">
      Principal Backend Engineer & Technical Manager
    </div>
    
    <div class="py-4 space-y-4 text-lg text-white/70 max-w-[750px]">
      <p>
        Eric Chen is a backend / infrastructure engineer focused on Go, distributed systems, AI applications, and fintech automation. 
        Building AI-driven systems, real-time architectures, and scalable cloud infrastructure.
      </p>
      <p>
        I specialize in turning complex technical challenges into robust, maintainable backend services, 
        with a deep focus on concurrency patterns, observability, and system reliability.
      </p>
    </div>

    <!-- Terminal Status Bar -->
    <div class="mt-6 font-mono text-sm bg-base-300 p-3 rounded-lg border border-white/10 shadow-inner max-w-[600px]">
      <div class="flex items-center gap-2 mb-1">
        <span class="w-3 h-3 rounded-full bg-error"></span>
        <span class="w-3 h-3 rounded-full bg-warning"></span>
        <span class="w-3 h-3 rounded-full bg-success"></span>
        <span class="ml-2 text-white/50 text-xs text-primary font-bold">magi-lab — session: established</span>
      </div>
      <div class="text-success mt-2">
        <span class="text-white/50">$</span> systemctl status magi-engine <span class="bg-success text-black px-1 ml-1 rounded">ACTIVE</span>
      </div>
      <div class="text-white/70">
        <span class="text-white/50">$</span> uptime: 3,652 days (Principal Backend Exp)
      </div>
    </div>

    <div class="mt-10 flex flex-wrap gap-4">
      <a class="btn btn-primary" href="/projects"> Explore Projects</a>
      <a class="btn btn-outline" href="https://fshiori.substack.com/" target="_blank"> Read Notes</a>
      <a class="btn btn-ghost border-white/20" href="https://github.com/fshiori" target="_blank">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" style="fill: currentColor;"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        GitHub
      </a>
    </div>
  </div>

  <div>
    <div class="text-3xl w-full font-bold mb-5 flex items-center gap-3">
      Featured Projects
      <span class="h-[1px] bg-white/10 grow"></span>
    </div>
  </div>

  <HorizontalCard
    title="MAGI (AI Debate System)"
    img="/post_img.webp"
    desc="Exploring how different LLMs reason, challenge, and converge toward better answers. Built as a multi-agent orchestration system to observe consensus patterns in complex decision-making."
    url="https://github.com/fshiori/magi"
    badge="Researching"
  />
  <div class="divider my-0 opacity-10"></div>
  <HorizontalCard
    title="FinexLend (Fintech Utility)"
    img="/post_img.webp"
    desc="A personal fintech utility for automating lending workflows on Bitfinex. Focused on operational efficiency, risk visibility, and automated strategy experimentation."
    url="https://finexlend.cc"
    badge="Active"
  />
  <div class="divider my-0 opacity-10"></div>
  <HorizontalCard
    title="ClassZero (Kids Interactive Story)"
    img="/post_img.webp"
    desc="An interactive storytelling platform for children. Leveraging AI to create dynamic narratives and real-time interactive elements, providing a unique educational experience."
    url="https://classzero.magilab.org"
    badge="Building"
  />

  <div>
    <div class="text-3xl w-full font-bold mb-5 mt-10 flex items-center gap-3">
      Latest Notes
      <span class="h-[1px] bg-white/10 grow"></span>
    </div>
  </div>

  <HorizontalCard
    title="Why I’m building Magi Lab"
    img="/post_img.webp"
    desc="Reflections on the intersection of AI, personal research, and the future of backend engineering."
    url="https://fshiori.substack.com/"
    target="_blank"
  />
  <div class="divider my-0 opacity-10"></div>
  <HorizontalCard
    title="AI agents are becoming backend services"
    img="/post_img.webp"
    desc="Exploring how LLM orchestration is shifting the paradigm of traditional microservices."
    url="https://fshiori.substack.com/"
    target="_blank"
  />
  <div class="divider my-0 opacity-10"></div>
  <HorizontalCard
    title="Notes on fintech automation risk"
    img="/post_img.webp"
    desc="A technical deep dive into reliability and observability in automated lending systems."
    url="https://fshiori.substack.com/"
    target="_blank"
  />
</BaseLayout>
