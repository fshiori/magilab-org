---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimeLineElement from "../components/cv/TimeLine.astro";
---

<BaseLayout title="Lab Stacks | Magi Lab" sideBarActiveItemID="cv">
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Lab Stacks</div>
  </div>

  <div class="mb-10 text-justify">
    Building modern, scalable, and intelligent systems with a focus on efficiency and user experience.
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Core Technologies</div>
  </div>

  <div class="time-line-container grid gap-4 mb-10">
    <TimeLineElement
      title="Golang"
      subtitle="High-performance backend systems and microservices."
    />
    <TimeLineElement
      title="Python"
      subtitle="AI/ML Research, Data Processing, and Automation scripts."
    />
    <TimeLineElement
      title="Cloudflare"
      subtitle="Edge computing, Workers, and Serverless architecture."
    />
    <TimeLineElement
      title="AI Agents"
      subtitle="LLM orchestration, prompt engineering, and autonomous systems."
    />
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Infrastructure & Tools</div>
  </div>

  <ul class="list-disc mx-6 mb-10 grid gap-2">
    <li>Docker & Containerization</li>
    <li>PostgreSQL & Redis</li>
    <li>Tailwind CSS & Astro</li>
    <li>Git / GitHub Actions CI/CD</li>
  </ul>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Focus Areas</div>
  </div>

  <ul class="list-disc md:columns-2 columns-1 mx-6">
    <li>Fintech Automation</li>
    <li>Generative AI Applications</li>
    <li>Interactive Storytelling</li>
    <li>Distributed Systems</li>
  </ul>
</BaseLayout>
