---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title = "Projects | Magi Lab" sideBarActiveItemID="projects">
  <div>
    <div class="text-3xl w-full font-bold mb-5 flex items-center gap-3">
      Core Projects
      <span class="h-[1px] bg-white/10 grow"></span>
    </div>
  </div>

  <HorizontalCard
    title="MAGI (AI Debate System)"
    img="/post_img.webp"
    desc="Exploring how different LLMs reason, challenge, and converge toward better answers. Built as a multi-agent orchestration system to observe consensus patterns in complex decision-making. (Go / Python / OpenAI / Anthropic)"
    url="https://github.com/fshiori/magi"
    badge="Researching"
  />
  <div class="divider my-0 opacity-10"></div>
  <HorizontalCard
    title="FinexLend (Fintech Utility)"
    img="/post_img.webp"
    desc="A personal fintech utility for automating lending workflows on Bitfinex. Focused on operational efficiency, risk visibility, and automated strategy experimentation. Built for high reliability and precision. (Go / Kafka / Redis / WebSocket)"
    url="https://finexlend.cc"
    badge="Active"
  />
  <div class="divider my-0 opacity-10"></div>
  <HorizontalCard
    title="ClassZero (Kids Interactive Story)"
    img="/post_img.webp"
    desc="An interactive storytelling platform for children. Leveraging AI to create dynamic narratives and real-time interactive elements, providing a unique educational experience. (Astro / Cloudflare Workers / AI Agents)"
    url="https://classzero.magilab.org"
    badge="Building"
  />
</BaseLayout>
